
@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<h4>Charts</h4>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<div class="container mt-4">
    <div class="row">
        <!-- Sol div: Pie Chart -->
        <div class="col-md-6">
            <i>Category Pie Chart</i>
            <div id="pie_chart" style="height: 500px;"> @{ Html.RenderAction("CategoryPieChart"); }</div>
            <br />
            
        </div>

        <!-- Sağ div: Stacked Bar Chart -->
        <div class="col-md-6">
            <i>Warehouse Stacked Chart</i>
            <div id="stacked_chart" style="height: 500px;"> @{ Html.RenderAction("WarehouseStackedChart"); }</div>
            
        </div>
    </div>
</div>
